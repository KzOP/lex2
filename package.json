{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "preinstall": "node -e \"const fs=require('fs');try{fs.unlinkSync('package-lock.json')}catch(e){}try{fs.unlinkSync('yarn.lock')}catch(e){}\"",
    "build": "pnpm run typecheck && pnpm -r --if-present run build",
    "typecheck:libs": "tsc --build",
    "typecheck": "pnpm run typecheck:libs && pnpm -r --filter \"./artifacts/**\" --filter \"./scripts\" --if-present run typecheck"
  },
  "private": true,
  "packageManager": "pnpm@10.26.1",
  "devDependencies": {
    "@types/archiver": "^8.0.0",
    "archiver": "^8.0.0",
    "prettier": "^3.8.3",
    "typescript": "~5.9.3"
  }
}
